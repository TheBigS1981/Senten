# Senten — Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.

# ---------------------------------------------------------------------------
# DeepL API
# ---------------------------------------------------------------------------
# API-Key von https://www.deepl.com/pro-api
# Ohne Key läuft die Anwendung im Mock-Modus (Platzhalter-Antworten).
DEEPL_API_KEY=

# ---------------------------------------------------------------------------
# Sicherheit
# ---------------------------------------------------------------------------
# Zufälligen Key generieren: openssl rand -hex 32
# WICHTIG: In Production unbedingt einen eigenen Key setzen!
SECRET_KEY=

# Session-Cookie mit Secure-Flag (Standard: true).
# false setzen wenn kein HTTPS (z.B. direkter HTTP-Zugriff ohne Reverse-Proxy).
# Bei HTTPS über Nginx Proxy Manager, Caddy, Traefik etc. auf true belassen.
SESSION_COOKIE_SECURE=true

# Swagger UI und API-Docs deaktivieren (Standard: true = Docs versteckt).
# false setzen in Development um /docs, /redoc und /openapi.json zu aktivieren.
IS_PRODUCTION=true

# Vertrauenswürdige Reverse-Proxy-IPs für X-Forwarded-For (kommagetrennt).
# X-Forwarded-For wird nur akzeptiert wenn der Request von einer dieser IPs kommt.
# Standard: 127.0.0.1,::1 (nur localhost)
TRUSTED_PROXIES=127.0.0.1,::1

# ---------------------------------------------------------------------------
# Datenbank
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./data/senten.db

# ---------------------------------------------------------------------------
# Nutzungslimits
# ---------------------------------------------------------------------------
MONTHLY_CHAR_LIMIT=500000

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
# Anfragen pro Minute für /api/translate und /api/write Endpunkte
RATE_LIMIT_PER_MINUTE=30
# Burst-Limit für kurze Lastspitzen
RATE_LIMIT_BURST=10

# ---------------------------------------------------------------------------
# CORS (optional)
# ---------------------------------------------------------------------------
# Kommagetrennte Liste erlaubter Origins, z.B.: https://example.com,https://app.example.com
# Leer lassen wenn nicht benötigt.
ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Authentifizierung — Modus wird automatisch erkannt
# ---------------------------------------------------------------------------
# Modus 1: OIDC (höchste Priorität, wenn OIDC_DISCOVERY_URL gesetzt)
# Beispiel für Authentik:
# OIDC_DISCOVERY_URL=https://auth.example.com/application/o/senten/.well-known/openid-configuration
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Modus 2: HTTP Basic Auth (wenn kein OIDC, aber AUTH_USERNAME + AUTH_PASSWORD gesetzt)
AUTH_USERNAME=
AUTH_PASSWORD=

# Modus 3: Anonym (kein Auth — für Heimnetz/VPN-Einsatz hinter Reverse-Proxy)
# Einfach alle Auth-Variablen leer lassen.

# ---------------------------------------------------------------------------
# Benutzerverwaltung (optional)
# ---------------------------------------------------------------------------
# Wenn gesetzt, wird beim ersten Start ein Admin-Benutzer angelegt.
# Nur wirksam solange noch keine Benutzer in der Datenbank existieren.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Anonymer Zugang erlaubt (Standard: false).
# true = Anonymer Zugriff ohne Login möglich (nur für vertrauenswürdige Netze).
ALLOW_ANONYMOUS=false

# Session-Lebensdauer in Stunden (Standard: 168 / 720 mit "Angemeldet bleiben").
SESSION_LIFETIME_HOURS=168
SESSION_LIFETIME_REMEMBER_HOURS=720

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Verzeichnis für Log-Dateien (Standard: data/)
LOG_DIR=data

# ---------------------------------------------------------------------------
# LLM Erweiterung (optional)
# ---------------------------------------------------------------------------
# Wenn LLM_PROVIDER gesetzt ist, erscheint in Übersetzen- und Optimieren-Tab
# ein Toggle zum Wechseln zwischen DeepL und LLM.
#
# Unterstützte Provider: openai | anthropic | ollama | openai-compatible
#
# Beispiel für OpenAI:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-...
#   LLM_TRANSLATE_MODEL=gpt-4o
#
# Beispiel für Anthropic:
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-...
#   LLM_TRANSLATE_MODEL=claude-3-5-sonnet-20241022
#
# Beispiel für Ollama (lokal):
#   LLM_PROVIDER=ollama
#   LLM_BASE_URL=http://localhost:11434
#   LLM_TRANSLATE_MODEL=llama3.2
#
# Beispiel für OpenAI-kompatiblen Proxy (z.B. LiteLLM):
#   LLM_PROVIDER=openai-compatible
#   LLM_BASE_URL=http://litellm:4000   # Pflicht für openai-compatible
#   LLM_API_KEY=optional-master-key    # Optional (leer lassen wenn kein Auth)
#   LLM_DISPLAY_NAME=LiteLLM          # Label im UI-Toggle
#   LLM_TRANSLATE_MODEL=gpt-4o
LLM_PROVIDER=

# API-Key für OpenAI oder Anthropic.
# Bei Ollama und openai-compatible optional (nur nötig bei gesicherter Instanz).
LLM_API_KEY=

# Base-URL — für Ollama und openai-compatible erforderlich.
# Standard für Ollama: http://localhost:11434
LLM_BASE_URL=

# Anzeigename im UI-Toggle (optional).
# Standard: Provider-Name (z.B. "openai"). Nützlich für openai-compatible Proxys.
# Beispiel: LiteLLM, My Proxy, vLLM
LLM_DISPLAY_NAME=

# Timeout in Sekunden für LLM-Anfragen (Standard: 30).
# Bei langsamen lokalen Modellen ggf. erhöhen (z.B. 120).
LLM_TIMEOUT=30

# Maximale Eingabelänge in Zeichen pro LLM-Anfrage (Standard: 5000).
# Schützt vor unbeabsichtigt hohen Kosten bei sehr langen Texten.
# Texte die länger sind werden mit HTTP 422 abgelehnt.
LLM_MAX_INPUT_CHARS=5000

# Modell-Name für Übersetzungen
# OpenAI-Beispiele:  gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Anthropic-Beispiele: claude-3-5-sonnet-20241022, claude-3-haiku-20240307
# Ollama-Beispiele:  llama3.2, mistral, qwen2.5
LLM_TRANSLATE_MODEL=gpt-4o

# Modell-Name für Textoptimierung (kann identisch mit LLM_TRANSLATE_MODEL sein)
LLM_WRITE_MODEL=gpt-4o


